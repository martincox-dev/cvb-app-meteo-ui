# ── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Coordenadas CVB (fijas)
LATITUDE=40.04375215857617
LONGITUDE=0.0651749140667065

# ── AEMET ────────────────────────────────────────────────────
# Opcional — sin clave se usan los feeds RSS públicos de avisos CAP
AEMET_API_KEY=
# Códigos de zona a monitorizar (separados por coma). Ej: AFCV771204,AFAP7712
AEMET_TARGET_ZONE_CODES=
# Palabras clave para filtrar alertas (separadas por coma)
AEMET_TARGET_KEYWORDS=

# ── Windguru ─────────────────────────────────────────────────
WINDY_API_KEY=
WINDGURU_STATIONS_URL=https://stations.windguru.cz/data_api.php

# ── BunnyDB / libSQL (histórico persistente de muestras y alertas) ──
# Sin estas variables el runtime usa memoria (no persiste entre reinicios)
LIBSQL_URL=
LIBSQL_AUTH_TOKEN=

# ── WhatsApp ─────────────────────────────────────────────────
# Identificador de sesión local (LocalAuth clientId)
WA_CLIENT_ID=cvb-group-list-temp
# IDs de grupos destino separados por coma (Junta CVB primero)
# Obtener con: npm run wa:test  (lista grupos disponibles)
WA_GROUP_IDS=
# Activar envío automático de alertas AEMET a los grupos
WA_AUTO_SEND_ENABLED=true
# Intervalo de comprobación en ms (mínimo 60000)
WA_AUTO_SEND_INTERVAL_MS=180000

# ── Bunny Storage (backup/restore sesión WhatsApp) ───────────
# Imprescindible en producción para no perder la sesión entre reinicios
BUNNY_STORAGE_HOST=storage.bunnycdn.com
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_WA_SESSION_OBJECT=state/wa-session.tgz

# ── Puppeteer / Chromium ──────────────────────────────────────
# En producción Alpine MC el startup command ya exporta estas vars
# En local Mac dejar comentadas (puppeteer descarga su propio Chromium)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
